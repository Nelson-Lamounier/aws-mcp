# ─── Local development ────────────────────────────────────────────────────────
# Point to the knowledge base repo root on your machine.
# The server reads wiki/ pages and index.md directly from the filesystem.
# No AWS credentials needed in this mode.
WIKI_LOCAL_PATH=/Users/nelsonlamounier/Desktop/portfolio/reasearch-brain/kowledge-base

# ─── Production (K8s pod) ────────────────────────────────────────────────────
# When WIKI_S3_BUCKET is set, WIKI_LOCAL_PATH is ignored.
# WIKI_S3_BUCKET=your-kb-bucket-name
# WIKI_KB_PREFIX=kb-docs

# ─── Server config ───────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
