# wiki-mcp — Environment Variables
# Copy to .env and fill in the values for local development.
# Production values are injected via Kubernetes ConfigMap and EC2 Instance Profile.

# ─────────────────────────────────────────────────────────────────────────────
# Backend selection (set exactly one)
# ─────────────────────────────────────────────────────────────────────────────

# LOCAL DEV — path to the knowledge-base directory on your machine.
# The directory must contain index.md at the root and a wiki/ subdirectory.
WIKI_LOCAL_PATH=/path/to/your/kb-docs

# PRODUCTION — S3 bucket containing the synced Markdown files.
# EC2 Instance Profile credentials are used automatically (no key needed).
# WIKI_S3_BUCKET=bedrock-dev-kb-data

# Optional S3 prefix for Markdown files (default: kb-docs)
# WIKI_KB_PREFIX=kb-docs

# ─────────────────────────────────────────────────────────────────────────────
# Server settings
# ─────────────────────────────────────────────────────────────────────────────

# HTTP server port (default: 8000)
PORT=8000

# Transport mode: leave empty for httpStream (K8s) or set to "stdio" for Claude Code
# MCP_MODE=stdio

# Service version propagated to /healthz responses
# SERVICE_VERSION=1.0.0
